# ── Copy this to .env and fill in real values ─────────────────────────────────
# NEVER commit .env to git

# App
PROJECT_NAME=MyEcommerceApp
ENVIRONMENT=development
DEBUG=true

# Security — generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-secure-random-string

# ── AI 用户系统（SQLite）──────────────────────────────────────────────────────
# JWT secret for SQLite-based user system — generate with: openssl rand -hex 32
USER_JWT_SECRET=change-me-to-another-secure-random-string
# JWT token expiry in hours (default: 72)
USER_JWT_EXPIRE_HOURS=72

# ── 管理员密钥 ────────────────────────────────────────────────────────────────
# Admin API key — generate with: openssl rand -hex 24
# Pass via HTTP Header:  X-Admin-Key: <value>
ADMIN_SECRET_KEY=change-me-to-a-secure-admin-key

# ── LLM ──────────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEFAULT_LLM_MODEL=deepseek-chat

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=apppassword

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── CORS（逗号分隔的允许来源，不要使用 *）─────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Email (optional) ──────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM=noreply@example.com
